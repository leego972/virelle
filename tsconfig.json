{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "lib": ["ES2022"]
  },
  "exclude": [
    "node_modules",
    "apps/mobile",
    "apps/desktop",
    "apps/web/client"
  ]
}
