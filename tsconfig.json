{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "noEmit": true
  },
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "apps", "**/node_modules", "**/dist", "**/build"]
}
