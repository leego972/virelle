{
  "name": "virelle",
  "private": true,
  "version": "0.0.0",
  "description": "Virelle Studios — AI-powered film production platform (monorepo)",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@virelle/web",
    "dev:mobile": "turbo run dev --filter=@virelle/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@virelle/web",
    "check": "turbo run check",
    "test": "turbo run test",
    "format": "turbo run format",
    "db:push": "turbo run db:push",
    "db:push:web": "turbo run db:push --filter=@virelle/web",
    "db:push:mobile": "turbo run db:push --filter=@virelle/mobile",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
